<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ seoTitle or (title + " — a quiet room") }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="theme-color" content="#08080c" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:title" content="{{ ogTitle or seoTitle or title }}" />
  <meta property="og:description" content="{{ ogDescription or description }}" />
  <meta property="og:image" content="/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="alternate" type="application/rss+xml" title="a quiet room" href="/feed.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v={{ assetVersion }}" />
</head>
<body>
  <canvas id="ambient"></canvas>
  <div class="atmosphere" aria-hidden="true">
    <div class="grain"></div>
    <div class="vignette"></div>
  </div>

  <!-- Everything inside #swup is swapped on navigation; the shell (canvas,
       atmosphere, sound) persists so the music never stops. -->
  <div id="swup">
    {% if header != false %}
    <header class="site-head">
      <a href="/home/" class="mark">a quiet room</a>
      <nav class="nav" aria-label="Primary">
        <a href="/journal/"{% if nav == "journal" %} aria-current="page"{% endif %}>journal</a>
        <a href="/projects/"{% if nav == "projects" %} aria-current="page"{% endif %}>projects</a>
        <a href="/about/"{% if nav == "about" %} aria-current="page"{% endif %}>about</a>
      </nav>
    </header>
    {% endif %}

    {{ content | safe }}

    {% if footer != false %}
    <footer class="site-foot">
      <span>a quiet room</span>
      <a href="/home/">a portal to my innerworld</a>
    </footer>
    {% endif %}
  </div>

  <button id="sound-toggle" class="skiper-toggle" aria-pressed="false" aria-label="Toggle ambient sound" title="Ambient sound">
    <span class="sk-reveal" aria-hidden="true">
      <span class="sk-title-wrap">
        <span class="sk-title" id="sk-title">{{ soundtrack.tracks[0].title if soundtrack.tracks and soundtrack.tracks.length else "ambient" }}</span>
      </span>
    </span>
    <span class="sk-knob" aria-hidden="true">
      <svg class="sk-play" viewBox="-1 0 12 14" xmlns="http://www.w3.org/2000/svg"><path d="M0.9375 13.2422C1.25 13.2422 1.51562 13.1172 1.82812 12.9375L10.9375 7.67188C11.5859 7.28906 11.8125 7.03906 11.8125 6.625C11.8125 6.21094 11.5859 5.96094 10.9375 5.58594L1.82812 0.3125C1.51562 0.132812 1.25 0.015625 0.9375 0.015625C0.359375 0.015625 0 0.453125 0 1.13281V12.1172C0 12.7969 0.359375 13.2422 0.9375 13.2422Z"/></svg>
      <span class="sk-eq"><i></i><i></i><i></i></span>
    </span>
  </button>

  <script id="soundtrack" type="application/json">{{ soundtrack.tracks | dump | safe }}</script>
  <script src="/js/main.js?v={{ assetVersion }}"></script>
</body>
</html>
