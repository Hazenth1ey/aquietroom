---
layout: base
nav: projects
seoTitle: "projects — a quiet room"
ogTitle: "projects — a quiet room"
description: "Things I've made and things I'm slowly tending to."
---
<main class="wrap wrap--wide">
  <p class="eyebrow" data-reveal="0">projects</p>
  <h1 class="title" data-reveal="1" style="font-size: clamp(2rem, 6vw, 3.25rem); margin-top: 1rem;">things I'm tending to</h1>
  <p class="lede" data-reveal="2" style="margin-top: 1.5rem; max-width: 40rem;">
    {{ projects.intro }}
  </p>

  <ul class="works">
    {% for p in projects.items %}
    <li class="work" data-reveal="{{ loop.index0 + 3 }}">
      <h3>{{ p.title }}{% if p.year %} <span class="year">{{ p.year }}</span>{% endif %}</h3>
      <p>{{ p.description }}</p>
      {% if p.tags and p.tags.length %}
      <div class="tags">
        {% for t in p.tags %}<span class="tag">{{ t }}</span>{% endfor %}
      </div>
      {% endif %}
      {% if p.url %}<p style="margin-top: 1rem;"><a class="work-link" href="{{ p.url }}">visit →</a></p>{% endif %}
    </li>
    {% endfor %}
  </ul>

  <a href="/" class="back">back to the door</a>
</main>
