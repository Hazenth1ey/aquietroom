---
layout: base
nav: about
seoTitle: "about — a quiet room"
ogTitle: "about — a quiet room"
ogType: profile
description: "About the person behind this quiet room."
---
{% macro icon(name) %}
{%- if name == "email" -%}<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
{%- elif name == "github" -%}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
{%- elif name == "twitter" -%}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
{%- elif name == "instagram" -%}<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
{%- elif name == "linkedin" -%}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
{%- elif name == "facebook" -%}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
{%- elif name == "rss" -%}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
{%- else -%}<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
{%- endif -%}
{% endmacro %}
<main class="wrap">
  <p class="eyebrow" data-reveal="0">{{ about.eyebrow }}</p>
  <h1 class="title" data-reveal="1" style="font-size: clamp(2rem, 6vw, 3.25rem); margin-top: 1rem;">{{ about.heading }}</h1>

  <div class="prose" data-reveal="2" style="margin-top: 2.5rem;">
    <p class="lede" style="margin-bottom: 2rem;">{{ about.lede }}</p>

    {{ about.body | md | safe }}

    {% if about.links_heading %}<h2>{{ about.links_heading }}</h2>{% endif %}
    {% if about.links_intro %}<p>{{ about.links_intro }}</p>{% endif %}

    {% if about.links and about.links.length %}
    <ul class="links">
      {% for l in about.links %}
      <li>
        <a href="{{ l.url }}"{% if l.icon != "email" %} rel="me"{% endif %}>
          {{ icon(l.icon) | safe }}
          {{ l.label }}
        </a>
      </li>
      {% endfor %}
    </ul>
    {% endif %}

    <a href="/" class="back">back to the door</a>
  </div>
</main>
